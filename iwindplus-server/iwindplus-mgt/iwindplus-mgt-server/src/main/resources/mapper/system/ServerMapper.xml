<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.iwindplus.mgt.server.dal.mapper.system.ServerMapper">
    <resultMap id="ServerBaseAliasVO" type="com.iwindplus.mgt.domain.vo.system.ServerBaseVO">
        <result property="id" column="sr_id"/>
        <result property="routeId" column="sr_route_id"/>
        <result property="name" column="sr_name"/>
    </resultMap>

    <resultMap id="ServerVO" type="com.iwindplus.mgt.domain.vo.system.ServerVO">
        <result property="id" column="id"/>
        <result property="createdTime" column="created_time"/>
        <result property="createdTimestamp" column="created_timestamp"/>
        <result property="createdBy" column="created_by"/>
        <result property="createdId" column="created_id"/>
        <result property="modifiedTime" column="modified_time"/>
        <result property="modifiedTimestamp" column="modified_timestamp"/>
        <result property="modifiedBy" column="modified_by"/>
        <result property="modifiedId" column="modified_id"/>
        <result property="deleted" column="deleted"/>
        <result property="version" column="version"/>
        <result property="remark" column="remark"/>
        <result property="status" column="status"/>
        <result property="name" column="name"/>
        <result property="routeId" column="route_id"/>
        <result property="uri" column="uri"/>
        <result property="predicates" column="predicates" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result property="filters" column="filters" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result property="seq" column="seq"/>
        <result property="hideFlag" column="hide_flag"/>
        <result property="buildInFlag" column="build_in_flag"/>
    </resultMap>

    <sql id="serverBaseAliasField">
        sr.id as server_id, sr.route_id as server_route_id, sr.name as server_name, sr.seq as server_seq
    </sql>

    <sql id="serverBaseExtendAliasField">
        sr.id as server_id, sr.route_id as server_route_id, sr.predicates as server_predicates, sr.filters as server_filters
    </sql>

    <select id="selectCountByPattern" resultType="java.lang.Long">
        select
            count(*)
        from `server`
        where JSON_SEARCH(predicates, 'all', #{pattern}, NULL, '$**.pattern') !=''
    </select>
</mapper>
