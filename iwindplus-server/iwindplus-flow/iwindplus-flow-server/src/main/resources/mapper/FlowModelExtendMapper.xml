<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.iwindplus.flow.server.dal.mapper.FlowModelExtendMapper">
    <sql id="modelExtendAliasField">
        fme.model_content, fme.form_content
    </sql>

    <sql id="inSql">
        <foreach collection="list" item="item" index="index" open="(" separator="," close=")">
            #{item}
        </foreach>
    </sql>

    <delete id="deleteByModelIds">
        delete from flow_model_extend
        where model_id in
        <include refid="inSql"/>
    </delete>

</mapper>
